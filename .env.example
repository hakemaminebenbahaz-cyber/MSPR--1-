# ── Base de données ──────────────────────────────────────────
# Local Docker (défaut)
POSTGRES_DB=obrail-db
POSTGRES_USER=railadmin
POSTGRES_PASSWORD=changeme

# Azure (remplace DATABASE_URL pour pointer vers Azure)
DATABASE_URL=postgresql://railadmin:changeme@postgres:5432/obrail-db

# ── API ──────────────────────────────────────────────────────
API_KEY=obrail-api-key-2026
SECRET_KEY=changeme-in-production

# ── Grafana ──────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
